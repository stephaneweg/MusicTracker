<Window x:Class="MusicTracker.Dialogs.FileBrowserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctl="clr-namespace:MusicTracker.Controls"
        Title="Ouvrir un fichier" Width="800" Height="540" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Window.Resources>
        <!-- A place button in the left sidebar (Récents, Bureau, lecteurs…). -->
        <Style x:Key="PlaceBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Foreground" Value="{StaticResource CommonForeground}"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="Transparent" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource SurfaceHoverBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- A small square icon button (Précédent / Remonter). -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Foreground" Value="{StaticResource CommonForeground}"/>
            <Setter Property="FontFamily" Value="Segoe UI Symbol"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{StaticResource LightBackground}" CornerRadius="5"
                                BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource SurfaceHoverBackground}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- File / folder list: one row = icon + name, right-aligned meta. -->
        <Style x:Key="EntryList" TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource DarkBackground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource CommonForeground}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
        <Style x:Key="EntryItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Foreground" Value="{StaticResource CommonForeground}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="b" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource SurfaceHoverBackground}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource AccentDeepBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource CommonBackground}" BorderBrush="{StaticResource OutlineColorBrush}" BorderThickness="3" CornerRadius="8">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar (drag) -->
            <Grid Grid.Row="0" ctl:WindowDrag.Enable="True" Background="{StaticResource CommonBackground}" Margin="0">
                <StackPanel Orientation="Horizontal" Margin="18,14,0,10">
                    <TextBlock x:Name="txtIcon" Text="📂" FontSize="15" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="txtTitle" Text="Ouvrir un fichier" Foreground="{StaticResource CommonForeground}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Content="✕" Click="btnClose_Click" HorizontalAlignment="Right" VerticalAlignment="Top" Width="34" Height="30"
                        Cursor="Hand" Foreground="{StaticResource SecondaryForeground}" Background="Transparent" BorderThickness="0" FontSize="13"/>
            </Grid>

            <!-- Path bar -->
            <Grid Grid.Row="1" Margin="16,2,16,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" x:Name="btnBack" Style="{StaticResource NavBtn}" Content="◀" Margin="0,0,6,0" Click="btnBack_Click" ToolTip="Précédent"/>
                <Button Grid.Column="1" x:Name="btnUp" Style="{StaticResource NavBtn}" Content="▲" Margin="0,0,8,0" Click="btnUp_Click" ToolTip="Dossier parent"/>
                <TextBox Grid.Column="2" x:Name="txtPath" VerticalContentAlignment="Center" Padding="8,0" KeyDown="txtPath_KeyDown"
                         Background="{StaticResource LightBackground}" Foreground="{StaticResource CommonForeground}"
                         BorderBrush="{StaticResource SubtleBorderBrush}"/>
            </Grid>

            <!-- Sidebar + list -->
            <Grid Grid.Row="2" Margin="16,0,16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="176"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource DarkBackground}" CornerRadius="6" Padding="6" Margin="0,0,10,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="placesPanel"/>
                    </ScrollViewer>
                </Border>

                <Border Grid.Column="1" Background="{StaticResource DarkBackground}" CornerRadius="6">
                    <Grid>
                        <ListBox x:Name="listFiles" Style="{StaticResource EntryList}" ItemContainerStyle="{StaticResource EntryItem}"
                                 SelectionChanged="listFiles_SelectionChanged" MouseDoubleClick="listFiles_DoubleClick" Padding="4">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="14" Margin="0,0,9,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Detail}" Foreground="{StaticResource SecondaryForeground}" FontSize="11" VerticalAlignment="Center" Margin="12,0,4,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock x:Name="txtEmpty" Text="Dossier vide" Foreground="{StaticResource SecondaryForeground}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Bottom bar -->
            <Grid Grid.Row="3" Margin="16,12,16,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Nom :" Foreground="{StaticResource CommonForeground}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtFileName" VerticalContentAlignment="Center" Padding="8,4" KeyDown="txtFileName_KeyDown"
                         Background="{StaticResource LightBackground}" Foreground="{StaticResource CommonForeground}" BorderBrush="{StaticResource SubtleBorderBrush}"/>
                <ComboBox Grid.Row="0" Grid.Column="2" x:Name="cboFilter" MinWidth="220" Margin="10,0,0,0" VerticalAlignment="Center"
                          SelectionChanged="cboFilter_SelectionChanged"/>

                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                    <Button Content="Annuler" Style="{StaticResource cancelButton}" Click="btnCancel_Click" Padding="18,5" Margin="0,0,8,0" Cursor="Hand"/>
                    <Button x:Name="btnAccept" Content="Ouvrir" Style="{StaticResource okButton}" Click="btnAccept_Click" Padding="22,5" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
