<Window x:Class="MusicTracker.Dialogs.NumberDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicTracker.Screens"
        mc:Ignorable="d" Foreground="{StaticResource CommonForeground}"
        Title="NumberDialog" Width="360" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">
    <Border Background="{StaticResource CommonBackground}" BorderBrush="{StaticResource OutlineColorBrush}" BorderThickness="3" CornerRadius="8">
        <StackPanel Margin="24,18">
            <TextBlock x:Name="titleBar" Text="{Binding Path=Message}" Foreground="{StaticResource CommonForeground}"
                       FontSize="15" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,12"/>
            <TextBox Style="{StaticResource labelTextBox}" Text="{Binding Path=Value, Mode=TwoWay}" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Annuler" Style="{StaticResource cancelButton}" Name="btnCancel" Padding="16,4" Margin="0,0,8,0" Cursor="Hand" Click="btnCancel_Click"/>
                <Button Content="OK" Name="btnOK" Style="{StaticResource okButton}" Padding="18,4" Cursor="Hand" Click="btnOK_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
