<Window x:Class="MusicTracker.Dialogs.AiElementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:ctl="clr-namespace:MusicTracker.Controls"
        mc:Ignorable="d"
        Title="Générer avec l'IA" SizeToContent="Height" Width="470" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AccentBrightBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource CommonForeground}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,10"/>
        </Style>
        <!-- Subtle secondary button (Copier / Coller). -->
        <Style x:Key="SubtleBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryForeground}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="5" BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource SurfaceHoverBackground}"/>
                                <Setter Property="Foreground" Value="{StaticResource CommonForeground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Background="{StaticResource CommonBackground}" BorderBrush="{StaticResource OutlineColorBrush}" BorderThickness="3" CornerRadius="8">
        <StackPanel Margin="24,18,24,20">
            <StackPanel Background="{StaticResource CommonBackground}"  ctl:WindowDrag.Enable="True"  Orientation="Horizontal" Margin="0,0,0,2" HorizontalAlignment="Stretch">
                <TextBlock Text="🤖" FontSize="15" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource CommonForeground}" />
                <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Foreground="{StaticResource CommonForeground}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock x:Name="txtContext" Foreground="{StaticResource SecondaryForeground}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4"/>

            <!-- Provider (collapsed once a key is present) -->
            <Expander x:Name="expModel" Margin="0,12,0,0" IsExpanded="True">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="MODÈLE" Style="{StaticResource SectionLabel}"/>
                        <TextBlock x:Name="txtModelSummary" Foreground="{StaticResource SecondaryForeground}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                </Expander.Header>
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Fournisseur :" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cboProvider" VerticalAlignment="Center" Width="130" HorizontalAlignment="Left" Margin="0,0,0,10" SelectionChanged="cboProvider_SelectionChanged"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Clé :" Style="{StaticResource FieldLabel}"/>
                    <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" x:Name="cboKey" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Gérer…" Click="btnManageKeys_Click" Margin="8,0,0,0" Padding="10,4" Cursor="Hand"
                                Background="Transparent" Foreground="{StaticResource AccentBrightBrush}" BorderThickness="0"
                                ToolTip="Ajouter / modifier / supprimer des clés API (Paramètres → Clés API)"/>
                    </Grid>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Modèle :" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="cboModel" IsEditable="True" VerticalAlignment="Center"/>
                </Grid>
            </Expander>

            <TextBlock Text="Intention" Foreground="{StaticResource CommonForeground}" Margin="0,14,0,5"/>
            <TextBox x:Name="txtIntention" Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

            <!-- Génération -->
            <TextBlock Text="GÉNÉRATION" Style="{StaticResource SectionLabel}" Margin="0,16,0,4"/>
            <Border Height="1" Background="{StaticResource SubtleBorderBrush}" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal">
                <Button x:Name="btnGenerate" Content="Générer" Style="{StaticResource okButton}" Click="btnGenerate_Click" Padding="20,5" FontSize="14" Cursor="Hand"/>
                <Button x:Name="btnCopyPrompt" Content="Copier le prompt" Style="{StaticResource SubtleBtn}" Click="btnCopyPrompt_Click" Margin="10,0,0,0"
                        ToolTip="Copie le prompt (sans appeler l'API) : colle-le dans un chat IA, puis reviens avec « Coller la réponse »."/>
                <Button x:Name="btnPasteResponse" Content="Coller la réponse" Style="{StaticResource SubtleBtn}" Click="btnPasteResponse_Click" Margin="8,0,0,0"
                        ToolTip="Colle le JSON copié depuis un chat IA : vérifie-le puis clique Confirmer pour l'appliquer."/>
            </StackPanel>
            <ProgressBar x:Name="progGen" IsIndeterminate="True" Height="3" Visibility="Collapsed" Margin="0,10,0,0" Background="#14151A" BorderThickness="0" Foreground="{StaticResource AccentBrush}"/>
            <TextBlock x:Name="txtStatus" Foreground="{StaticResource SecondaryForeground}" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>

            <Expander Header="Avancé — JSON" IsExpanded="False" Margin="0,10,0,0" Foreground="{StaticResource SecondaryForeground}" FontSize="11">
                <TextBox x:Name="txtResult" Height="120" IsReadOnly="True" FontFamily="Consolas" FontSize="11" Margin="0,6,0,0"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap"
                         Background="{StaticResource DarkBackground}" Foreground="#CCCCCC"/>
            </Expander>

            <!-- Footer -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Annuler" Style="{StaticResource cancelButton}" Click="btnCancel_Click" Padding="16,4" Margin="0,0,8,0" Cursor="Hand"/>
                <Button x:Name="btnApply" Content="Confirmer" Style="{StaticResource okButton}" Click="btnApply_Click" Padding="18,4" Cursor="Hand" IsEnabled="False"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
