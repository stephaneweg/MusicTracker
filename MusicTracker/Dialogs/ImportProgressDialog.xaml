<Window x:Class="MusicTracker.Dialogs.ImportProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctl="clr-namespace:MusicTracker.Controls"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Import" SizeToContent="WidthAndHeight" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True">
    <Border Background="{StaticResource CommonBackground}" BorderBrush="{StaticResource OutlineColorBrush}" BorderThickness="3" CornerRadius="8">
        <StackPanel Margin="26,22" Width="380">
            <Border Background="{StaticResource CommonBackground}" CornerRadius="5,5,0,0"
                    Margin="-26,-22,-26,14" Padding="26,22,26,10">
                <TextBlock Text="Import en cours…" Foreground="{StaticResource CommonForeground}"
                           FontSize="16" FontWeight="Bold"/>
            </Border>
            <ProgressBar x:Name="bar" Minimum="0" Maximum="1" Height="22"
                         Background="#22000000" Foreground="#44FF88" BorderBrush="#444444" BorderThickness="1"/>
            <TextBlock x:Name="txtStatus" Text="" Foreground="#AAAAAA" HorizontalAlignment="Center" Margin="0,8,0,0"/>
        </StackPanel>
    </Border>
</Window>

