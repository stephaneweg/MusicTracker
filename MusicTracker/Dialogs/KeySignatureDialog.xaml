<Window x:Class="MusicTracker.Dialogs.KeySignatureDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctl="clr-namespace:MusicTracker.Controls"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Tonalité" SizeToContent="WidthAndHeight" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">
    <Border Background="{StaticResource CommonBackground}" BorderBrush="{StaticResource OutlineColorBrush}" BorderThickness="3" CornerRadius="8">
        <StackPanel Margin="26,22" MinWidth="300">
            <Border Background="{StaticResource CommonBackground}" CornerRadius="5,5,0,0"
                    Margin="-26,-22,-26,6" Padding="26,22,26,10">
                <TextBlock Text="Tonalité détectée" Foreground="{StaticResource CommonForeground}"
                           FontSize="16" FontWeight="Bold"/>
            </Border>
            <TextBlock Text="Vérifiez et corrigez si besoin la tonalité du morceau importé."
                       Foreground="#888888" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,16" MaxWidth="300"/>

            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="cboTonic" Width="56" VerticalAlignment="Center"/>
                <ToggleButton x:Name="tglSharp" Content="♯" Width="28" VerticalAlignment="Center" Margin="6,0,0,0" Click="TglSharp_Click" Cursor="Hand"/>
                <ToggleButton x:Name="tglFlat" Content="♭" Width="28" VerticalAlignment="Center" Margin="3,0,0,0" Click="TglFlat_Click" Cursor="Hand"/>
                <ComboBox x:Name="cboMode" Width="92" VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>

            <TextBlock Text="Mesure" Foreground="{StaticResource CommonForeground}" FontWeight="Bold" Margin="0,16,0,4"/>
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="txtNum" Width="40" VerticalAlignment="Center" TextAlignment="Center"/>
                <TextBlock Text="/" Foreground="{StaticResource CommonForeground}" VerticalAlignment="Center" Margin="6,0,6,0" FontSize="16"/>
                <ComboBox x:Name="cboDen" Width="56" VerticalAlignment="Center">
                    <ComboBoxItem>2</ComboBoxItem>
                    <ComboBoxItem>4</ComboBoxItem>
                    <ComboBoxItem>8</ComboBoxItem>
                    <ComboBoxItem>16</ComboBoxItem>
                </ComboBox>
            </StackPanel>
            <TextBlock x:Name="txtMeterHint" Foreground="#C8A24A" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0" MaxWidth="300" Visibility="Collapsed"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Annuler" Style="{StaticResource cancelButton}" Click="btnCancel_Click" Padding="16,4" Margin="0,0,8,0" Cursor="Hand"/>
                <Button Content="OK" Style="{StaticResource okButton}" Click="btnOk_Click" Padding="16,4" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
