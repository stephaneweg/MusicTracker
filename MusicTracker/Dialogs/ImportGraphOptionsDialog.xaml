<Window x:Class="MusicTracker.Dialogs.ImportGraphOptionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctl="clr-namespace:MusicTracker.Controls"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Import graphe" SizeToContent="WidthAndHeight" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">
    <Border Background="{StaticResource CommonBackground}" BorderBrush="{StaticResource OutlineColorBrush}" BorderThickness="3" CornerRadius="8">
        <StackPanel Margin="26,22" MinWidth="320">
            <Border Background="{StaticResource CommonBackground}" CornerRadius="5,5,0,0"
                    Margin="-26,-22,-26,18" Padding="26,22,26,10">
                <TextBlock Text="Découpage en riffs" Foreground="{StaticResource CommonForeground}"
                           FontSize="16" FontWeight="Bold"/>
            </Border>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Mesures par riff :" Foreground="{StaticResource CommonForeground}"
                           VerticalAlignment="Center" Margin="0,0,12,10"/>
                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cboMeasures" IsEditable="True" Text="1" Margin="0,0,0,10">
                    <ComboBoxItem>1</ComboBoxItem>
                    <ComboBoxItem>2</ComboBoxItem>
                    <ComboBoxItem>4</ComboBoxItem>
                    <ComboBoxItem>8</ComboBoxItem>
                    <ComboBoxItem>16</ComboBoxItem>
                    <ComboBoxItem>24</ComboBoxItem>
                    <ComboBoxItem>32</ComboBoxItem>
                    <ComboBoxItem>64</ComboBoxItem>
                </ComboBox>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Slices par temps (précision) :" Foreground="{StaticResource CommonForeground}"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cboPrecision" IsEditable="True" Text="24">
                    <ComboBoxItem>4</ComboBoxItem>
                    <ComboBoxItem>6</ComboBoxItem>
                    <ComboBoxItem>8</ComboBoxItem>
                    <ComboBoxItem>12</ComboBoxItem>
                    <ComboBoxItem>16</ComboBoxItem>
                    <ComboBoxItem>24</ComboBoxItem>
                    <ComboBoxItem>48</ComboBoxItem>
                </ComboBox>
            </Grid>

            <CheckBox x:Name="chkVolume" IsChecked="False" Foreground="{StaticResource CommonForeground}" Margin="0,14,0,0"
                      Content="Importer les variations de volume (dynamiques)"/>
            <TextBlock x:Name="txtVolumeNote" Text="Décoché = un seul riff par groupe (pas de nœuds Set-volume) → beaucoup moins de nœuds sur les longues musiques."
                       Foreground="#888888" FontSize="10" TextWrapping="Wrap" Margin="22,2,0,0" MaxWidth="330"/>

            <TextBlock Text="Le fichier est analysé à 24 slices/temps ; une autre valeur ré-échantillonne le riff."
                       Foreground="#888888" FontSize="10" TextWrapping="Wrap" Margin="0,12,0,0" MaxWidth="330"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Annuler" Style="{StaticResource cancelButton}" Click="btnCancel_Click" Padding="16,4" Margin="0,0,8,0" Cursor="Hand"/>
                <Button Content="Importer" Style="{StaticResource okButton}" Click="btnOk_Click" Padding="16,4" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>

