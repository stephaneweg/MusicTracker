<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         DESIGN TOKENS  (dark, flat, "n-Track Studio 10" pro look)
         ============================================================
         Accent .... teal/cyan  #1FB6C3  (bright #3BCEDA / deep #178C97)
         Surfaces .. layered neutral greys, no gradients, no bevels
         Text ...... readable light greys
         NOTE: key NAMES are preserved for backward compatibility;
         only their VALUES changed. Old vertical gradients are now
         "flat" (identical stops) so the visual is flat while the
         resource type stays a Brush wherever it was consumed.
         ============================================================ -->

    <!-- Accent -->
    <Color x:Key="OutlineColor"  R="31" G="182" B="195" A="255"/>   <!-- #1FB6C3 teal -->
    <Color x:Key="OutlineColor2" R="59" G="206" B="218" A="255"/>   <!-- #3BCEDA bright teal -->

    <!-- Surfaces -->
    <Color x:Key="CommonBackgroundColor"  R="35" G="36" B="41" A="255"/>   <!-- #232429 panel base -->
    <Color x:Key="LightBackgroundColor"   R="44" G="46" B="53" A="255"/>   <!-- #2C2E35 surface -->
    <Color x:Key="TabItem.Static.BackgroundColor"   R="38" G="39" B="44" A="255"/> <!-- #26272C -->
    <Color x:Key="Expander.Content.BackgroundColor" R="30" G="31" B="36" A="255"/> <!-- #1E1F24 -->

    <!--SLIDERS (flat groove)-->
    <LinearGradientBrush x:Key="HorizontalSliderTrackNormalBackground" EndPoint="0,1" StartPoint="0,0">
        <GradientStop Color="#141519" Offset="0"/>
        <GradientStop Color="#141519" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="VerticalSliderTrackNormalBackground" EndPoint="1,0" StartPoint="0,0">
        <GradientStop Color="#141519" Offset="0"/>
        <GradientStop Color="#141519" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="DisabledTextBoxForeground" Color="#7A7F87"/>
    <SolidColorBrush x:Key="DisabledTextBoxOuterBackground" Color="#2A2C31"/>
    <LinearGradientBrush x:Key="DisabledTextBoxOuterBorder" EndPoint="0,1" StartPoint="0,0">
        <GradientStop Color="#14151A" Offset="0"/>
        <GradientStop Color="#14151A" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="DisabledTextBoxInnerBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="DisabledTextBoxInnerBorder" Color="Transparent"/>

    <SolidColorBrush x:Key="TextBoxForeground" Color="#C9CDD3"/>
    <SolidColorBrush x:Key="TextBoxOuterBackground" Color="#2A2C31"/>
    <SolidColorBrush x:Key="TextBoxOuterBorder" Color="#14151A"/>
    <SolidColorBrush x:Key="TextBoxInnerBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="TextBoxInnerBorder" Color="Transparent"/>

    <SolidColorBrush x:Key="HoverTextBoxForeground" Color="#E9EAED"/>
    <SolidColorBrush x:Key="HoverTextBoxOuterBackground" Color="#33353C"/>
    <SolidColorBrush x:Key="HoverTextBoxOuterBorder" Color="#3A3D45"/>
    <SolidColorBrush x:Key="HoverTextBoxInnerBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="HoverTextBoxInnerBorder" Color="Transparent"/>

    <SolidColorBrush x:Key="FocusedTextBoxForeground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="FocusedTextBoxOuterBackground" Color="#2A2C31"/>
    <SolidColorBrush x:Key="FocusedTextBoxOuterBorder" Color="{StaticResource OutlineColor}" />
    <SolidColorBrush x:Key="FocusedTextBoxInnerBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="FocusedTextBoxInnerBorder" Color="Transparent"/>

    <SolidColorBrush x:Key="ButtonForeground" Color="#E9EAED"/>
    <SolidColorBrush x:Key="ButtonInnerBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="ButtonInnerBorder" Color="Transparent"/>
    <LinearGradientBrush x:Key="ButtonOuterBorder" EndPoint="0,1" StartPoint="0,0">
        <GradientStop Color="#3A3D45" Offset="0"/>
        <GradientStop Color="#3A3D45" Offset="1"/>
    </LinearGradientBrush>


    <SolidColorBrush x:Key="DisabledButtonForeground" Color="#626770"/>
    <SolidColorBrush x:Key="DisabledButtonInnerBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="DisabledButtonInnerBorder" Color="Transparent"/>

    <SolidColorBrush x:Key="HoverButtonForeground" Color="#FFFFFF"/>
    <LinearGradientBrush x:Key="HoverButtonOuterBackground" EndPoint="0,1" StartPoint="0,0">
        <GradientStop Color="#33353C" Offset="0"/>
        <GradientStop Color="#33353C" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="HoverButtonOuterBorder" EndPoint="0,1" StartPoint="0,0">
        <GradientStop Color="#3A3D45" Offset="0"/>
        <GradientStop Color="#3A3D45" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="HoverButtonInnerBackground" Color="#14FFFFFF"/>
    <SolidColorBrush x:Key="HoverButtonInnerBorder" Color="#14FFFFFF"/>

    <SolidColorBrush x:Key="PressedButtonForeground" Color="#FFFFFF"/>
    <LinearGradientBrush x:Key="PressedButtonOuterBackground" EndPoint="0,1" StartPoint="0,0">
        <GradientStop Color="#178C97" Offset="0"/>
        <GradientStop Color="#178C97" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="PressedButtonOuterBorder" EndPoint="0,1" StartPoint="0,0">
        <GradientStop Color="#178C97" Offset="0"/>
        <GradientStop Color="#178C97" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="PressedButtonInnerBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="PressedButtonInnerBorder" Color="Transparent"/>


    <SolidColorBrush x:Key="OutlineColorBrush2" Color="{StaticResource OutlineColor2}"/>
    <SolidColorBrush x:Key="OutlineColorBrush" Color="{StaticResource OutlineColor}"/>
    <SolidColorBrush x:Key="CommonBackground" Color="{StaticResource CommonBackgroundColor}"/>
    <SolidColorBrush x:Key="LightBackground" Color="{StaticResource LightBackgroundColor}"/>
    <SolidColorBrush x:Key="DarkBackground" Color="#1A1B1F"/>
    <SolidColorBrush x:Key="CommonForeground" Color="#E9EAED"/>
    <SolidColorBrush x:Key="CommonBorderBrush" Color="#121317"/>

    <!-- extra semantic tokens (new; safe additive) -->
    <SolidColorBrush x:Key="SecondaryForeground" Color="#9BA1AA"/>
    <SolidColorBrush x:Key="SurfaceHoverBackground" Color="#33353C"/>
    <SolidColorBrush x:Key="SubtleBorderBrush" Color="#3A3D45"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource OutlineColor}"/>
    <SolidColorBrush x:Key="AccentBrightBrush" Color="{StaticResource OutlineColor2}"/>
    <SolidColorBrush x:Key="AccentDeepBrush" Color="#178C97"/>
    <SolidColorBrush x:Key="AccentMutedBrush" Color="#2833383E"/>

    <SolidColorBrush x:Key="TabItemOverForeground" Color="#3BCEDA"/>
    <SolidColorBrush x:Key="SelectedTabItemForeground" Color="#FFFFFFFF"/>
    <LinearGradientBrush x:Key="DisabledButtonOuterBackground" EndPoint="0,1" StartPoint="0,0">
        <GradientStop Color="#2A2C31" Offset="0"/>
        <GradientStop Color="#2A2C31" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="DisabledButtonOuterBorder" EndPoint="0,1" StartPoint="0,0">
        <GradientStop Color="#14151A" Offset="0"/>
        <GradientStop Color="#14151A" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ButtonOuterBackground" EndPoint="0,1" StartPoint="0,0">
        <GradientStop Color="#2C2E35" Offset="0"/>
        <GradientStop Color="#2C2E35" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SelectedTabBackground" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Offset="0" Color="#232429"/>
        <GradientStop Offset="0.7" Color="#232429"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="comboBoxTextBoxBackGround" Color="#2A2C31" />

    <SolidColorBrush x:Key="ComboBoxItemForeground" Color="#E9EAED"/>
    <SolidColorBrush x:Key="comboBoxForeground" Color="#E9EAED" />
    <LinearGradientBrush x:Key="comboBoxBackGround" EndPoint="0,1" StartPoint="0,0">
        <GradientStop Offset="0" Color="#33353C"/>
        <GradientStop Offset="1" Color="#33353C"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="comboBoxBorder" EndPoint="0,1" StartPoint="0,0">
        <GradientStop Offset="0" Color="#14151A"/>
        <GradientStop Offset="1" Color="#14151A"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="comboBoxPressedBackground" EndPoint="0,1" StartPoint="0,0">
        <GradientStop Offset="1" Color="#178C97"/>
        <GradientStop Offset="0" Color="#178C97"/>
    </LinearGradientBrush>


    <SolidColorBrush x:Key="comboBoxTextBoxOverBackGround" Color="#33353C" />
    <LinearGradientBrush x:Key="comboBoxOverBackGround" EndPoint="0,1" StartPoint="0,0">
        <GradientStop Offset="0" Color="#3A3D45"/>
        <GradientStop Offset="1" Color="#3A3D45"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ComboBoxPopUpBackground" EndPoint="0,1" StartPoint="0,0">
        <GradientStop Color="#26272C" Offset="0"/>
        <GradientStop Color="#26272C" Offset="1"/>
    </LinearGradientBrush>



    <Style TargetType="UserControl">
        <Setter Property="Background" Value="{StaticResource CommonBackground}"/>
    </Style>

    <LinearGradientBrush x:Key="Expander.Header.Background" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Offset="0" Color="#2C2E35"/>
        <GradientStop Offset="1" Color="#2C2E35"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Expander.Header.Expanded.Background" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Offset="0" Color="#232429"/>
        <GradientStop Offset="1" Color="#232429"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Expander.Header.Over.Background" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Offset="0" Color="#33353C"/>
        <GradientStop Offset="1" Color="#33353C"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="Expander.Content.Background" Color="#1E1F24"/>
    <SolidColorBrush x:Key="Expander.Header.Border.Top" Color="#3A3D45"/>
    <SolidColorBrush x:Key="Expander.Header.Border.Bottom" Color="#121317"/>


    <SolidColorBrush x:Key="GroupBoxOuterBackground" Color="#2C2E35"/>
    <SolidColorBrush x:Key="GroupBoxOuterBorder" Color="#121317"/>

    <SolidColorBrush x:Key="GroupBoxInnerBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="GroupBoxInnerBorder" Color="Transparent"/>

    <LinearGradientBrush x:Key="DisabledGroupBoxHeaderOuterBackground" EndPoint="0,1" StartPoint="0,0">
        <GradientStop Color="#2A2C31" Offset="0"/>
        <GradientStop Color="#2A2C31" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="DisabledGroupBoxOuterBackground" Color="#2A2C31"/>
    <SolidColorBrush x:Key="DisabledGroupBoxOuterBorder" Color="#14151A"/>
    <SolidColorBrush x:Key="DisabledGroupBoxInnerBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="DisabledGroupBoxInnerBorder" Color="Transparent"/>

    <SolidColorBrush x:Key="TabItem.Static.Background" Color="#26272C"/>
    <SolidColorBrush x:Key="TabItem.Static.Border" Color="#121317"/>
    <SolidColorBrush x:Key="TabItem.MouseOver.Background"  Color="#2C2E35"/>

    <Style TargetType="{x:Type Border}" x:Key="PopUPBorderStyle">
        <Setter Property="Background" Value="#26272C"/>
        <Setter Property="BorderBrush" Value="#121317"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
    </Style>
</ResourceDictionary>
