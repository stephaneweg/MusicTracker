<UserControl x:Class="MusicTracker.Screens.HomeScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ctl="clr-namespace:MusicTracker.Controls"
             mc:Ignorable="d"
             d:DesignHeight="620" d:DesignWidth="1200"
             Background="{StaticResource CommonBackground}">
    <UserControl.Resources>
        <!-- Action card: icon chip + title + description, surface at rest, accent border + lift on hover. -->
        <Style x:Key="ActionCard" TargetType="Button">
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Foreground" Value="{StaticResource CommonForeground}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{StaticResource LightBackground}" CornerRadius="10"
                                BorderThickness="1" BorderBrush="{StaticResource SubtleBorderBrush}" Padding="16,13">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceHoverBackground}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ==== Resources widget (Astuce du jour / Nouveautés) ==== -->
        <!-- Card shell, its teal title badge and the ‹ › browse arrows. Only the tip TEXT and the news LIST
             are filled from code-behind; everything below is pure layout. -->
        <Style x:Key="ResourceCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource LightBackground}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource SubtleBorderBrush}"/>
            <Setter Property="Padding" Value="14,12"/>
            <!-- No Width/Margin here: the hosting ResponsiveWrapPanel owns cell width and spacing, and a MaxWidth
                 would stop a card from filling the row when the pane is too narrow to show both side by side. -->
        </Style>
        <!-- White glyph on a rounded teal badge (emoji render monochrome in WPF, so they take the Foreground). -->
        <Style x:Key="CardBadge" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AccentBrightBrush}"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="Margin" Value="0,0,7,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CardBadgeGlyph" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AccentBrightBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ArrowBtn" TargetType="Button">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryForeground}"/>
            <Setter Property="Padding" Value="6,0"/>
        </Style>

        <!-- Template card: icon chip + name + description + tags; hover accent border. -->
        <Style x:Key="TemplateCard" TargetType="Button">
            <!-- Width and spacing come from the hosting ResponsiveWrapPanel so the cards can stretch when the
                 pane is too narrow for 4 columns. -->
            <Setter Property="Height" Value="150"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="Foreground" Value="{StaticResource CommonForeground}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{StaticResource LightBackground}" CornerRadius="10"
                                BorderThickness="1" BorderBrush="{StaticResource SubtleBorderBrush}" Padding="14,13">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceHoverBackground}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Subtle text button (footer). -->
        <Style x:Key="LinkBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryForeground}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceHoverBackground}"/>
                                <Setter Property="Foreground" Value="{StaticResource CommonForeground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Recent-file row. -->
        <Style x:Key="RecentItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border x:Name="bd" Grid.Row="0" Background="Transparent" BorderBrush="Transparent" BorderThickness="2" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                            <!-- hairline separator between rows, barely lighter than the panel -->
                            <Border x:Name="sep" Grid.Row="1" Height="1" Background="#55565C" Margin="6,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceHoverBackground}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentDeepBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Ambient equalizer along the bottom of the whole page (flat teal bars, faint; built in code-behind). -->
        <Canvas x:Name="eqCanvas" Grid.ColumnSpan="2" IsHitTestVisible="False" VerticalAlignment="Bottom" Height="420" Opacity="0.09">
            <Canvas.OpacityMask>
                <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                    <GradientStop Offset="0" Color="White"/>
                    <GradientStop Offset="0.2" Color="#88FFFFFF"/>
                    <GradientStop Offset="1" Color="Transparent"/>
                </LinearGradientBrush>
            </Canvas.OpacityMask>
        </Canvas>

        <!-- ===== Left: recent musics ===== -->
        <Border Grid.Column="0" Background="{StaticResource CommonBackground}" BorderBrush="{StaticResource CommonBorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel Margin="16,18">
                <TextBlock DockPanel.Dock="Top" Text="RÉCENTS" Foreground="{StaticResource AccentBrightBrush}"
                           FontSize="11" FontWeight="SemiBold" Margin="4,0,0,10"/>
                <TextBlock DockPanel.Dock="Bottom" Text="Double-cliquez pour ouvrir" Foreground="{StaticResource SecondaryForeground}" FontSize="11" Margin="4,8,0,0"/>
                <Grid>
                    <ListBox x:Name="listRecent" Background="Transparent" BorderThickness="0" Foreground="White"
                             ItemContainerStyle="{StaticResource RecentItem}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             MouseDoubleClick="ListRecent_DoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <!-- File icon chip -->
                                    <Border DockPanel.Dock="Left" Width="30" Height="30" CornerRadius="7" Background="#2A2C31" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <TextBlock Text="🎵" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <!-- Mode pill (hidden when Mode is empty) -->
                                    <Border DockPanel.Dock="Right" Background="#2A2C31" CornerRadius="4" Padding="6,2" VerticalAlignment="Center" Margin="8,0,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Mode}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Mode}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Mode}" FontSize="10" Foreground="{StaticResource SecondaryForeground}"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" Foreground="White" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Folder}" Foreground="#6A6F78" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <!-- Empty state (toggled in code-behind). -->
                    <StackPanel x:Name="emptyState" VerticalAlignment="Top" Margin="4,12,0,0" Visibility="Collapsed">
                        <TextBlock Text="Aucune musique récente." Foreground="{StaticResource SecondaryForeground}" FontSize="12"/>
                        <TextBlock Text="Créez-en une pour commencer." Foreground="#6A6F78" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </DockPanel>
        </Border>
        <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <!-- ===== Right: hero + action cards ===== -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- Crossfade backdrop: a riff piano-roll (left) dissolving into a drum grid (right), both built in
                 code-behind and faded via opacity masks. Sits behind the hero content. -->
                <Border Grid.Row="0" Name="banner" VerticalAlignment="Top" Margin="30" Padding="5" CornerRadius="10" BorderThickness="1" BorderBrush="{StaticResource SubtleBorderBrush}">
                    <Grid>

                        <!-- backdrop wrapper: global vertical fade to transparent at the bottom. Composes with each
                         canvas's own horizontal crossfade mask (masks multiply down the visual tree). -->
                        <Grid>
                            <Grid.OpacityMask>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Offset="0" Color="White"/>
                                    <GradientStop Offset="0.1" Color="White"/>
                                    <GradientStop Offset="1" Color="Transparent"/>
                                </LinearGradientBrush>
                            </Grid.OpacityMask>

                            <Canvas x:Name="bannerRiff" IsHitTestVisible="False" Opacity="0.3">
                                <Canvas.OpacityMask>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Offset="0" Color="white"/>
                                        <GradientStop Offset="0.7" Color="Transparent"/>
                                        <GradientStop Offset="1" Color="Transparent"/>
                                    </LinearGradientBrush>
                                </Canvas.OpacityMask>
                            </Canvas>
                            <Canvas x:Name="bannerDrum" IsHitTestVisible="False" Opacity="0.3">
                                <Canvas.OpacityMask>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Offset="0" Color="Transparent"/>
                                        <GradientStop Offset="0.3" Color="Transparent"/>
                                        <GradientStop Offset="1" Color="white"/>
                                    </LinearGradientBrush>
                                </Canvas.OpacityMask>
                            </Canvas>
                        </Grid>
                        <StackPanel>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="440" Margin="0,30,0,30">
                                <!-- Wordmark -->
                                <StackPanel Orientation="Horizontal" Margin="2,0,0,4" HorizontalAlignment="Center">
                                    <Ellipse Width="16" Height="16" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Aria Studio" Foreground="{StaticResource CommonForeground}" FontSize="32" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBlock Text="Composez, arrangez et séquencez vos morceaux." HorizontalAlignment="Center" Foreground="{StaticResource SecondaryForeground}"
                            FontSize="13" Margin="2,0,0,26"/>
                            </StackPanel>
                            <ctl:ReflowButtons HorizontalAlignment="Stretch" Margin="0,0,0,30" Gap="12">
                                <!-- Nouvelle musique (primary — accent chip) -->
                                <Button Style="{StaticResource ActionCard}" Margin="0" Click="BtnNewSequencer_Click">
                                    <DockPanel>
                                        <Border DockPanel.Dock="Left" Width="42" Height="42" CornerRadius="9" Background="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,14,0">
                                            <TextBlock Text="＋" FontSize="22" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock DockPanel.Dock="Right" Text="›" Foreground="{StaticResource SecondaryForeground}" FontSize="22" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Nouvelle musique" Foreground="{StaticResource CommonForeground}" FontSize="15" FontWeight="SemiBold"/>
                                            <TextBlock Text="Partir d'une timeline vierge." Foreground="{StaticResource SecondaryForeground}" FontSize="12" Margin="0,1,0,0"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Button>

                                <!-- Composer avec l'IA -->
                                <Button Style="{StaticResource ActionCard}" Margin="0" Click="BtnComposeAi_Click"
            ToolTip="Décris un style + une longueur ; l'IA génère un morceau, ouvert dans un nouvel onglet.">
                                    <DockPanel>
                                        <Border DockPanel.Dock="Left" Width="42" Height="42" CornerRadius="9" Background="#2A2C31" VerticalAlignment="Center" Margin="0,0,14,0">
                                            <TextBlock Text="🤖" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock DockPanel.Dock="Right" Text="›" Foreground="{StaticResource SecondaryForeground}" FontSize="22" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Composer avec l'IA" Foreground="{StaticResource CommonForeground}" FontSize="15" FontWeight="SemiBold"/>
                                            <TextBlock Text="Décris un style, l'IA arrange le morceau." Foreground="{StaticResource SecondaryForeground}" FontSize="12" Margin="0,1,0,0"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Button>

                                <!-- Ouvrir un fichier -->
                                <Button Style="{StaticResource ActionCard}" Margin="0" Click="BtnOpen_Click">
                                    <DockPanel>
                                        <Border DockPanel.Dock="Left" Width="42" Height="42" CornerRadius="9" Background="#2A2C31" VerticalAlignment="Center" Margin="0,0,14,0">
                                            <TextBlock Text="📂" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock DockPanel.Dock="Right" Text="›" Foreground="{StaticResource SecondaryForeground}" FontSize="22" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Ouvrir un fichier…" Foreground="{StaticResource CommonForeground}" FontSize="15" FontWeight="SemiBold"/>
                                            <TextBlock Text="Reprendre un projet enregistré." Foreground="{StaticResource SecondaryForeground}" FontSize="12" Margin="0,1,0,0"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Button>
                            </ctl:ReflowButtons>
                        </StackPanel>

                    </Grid>
                </Border>

                <!-- Templates from Data/templates/*.json (cards built in code-behind) + two "add" links. -->
                <StackPanel Grid.Row="1" Margin="30,0,30,20">
                    <TextBlock Text="MODÈLES DE PROJET" Foreground="{StaticResource AccentBrightBrush}" FontSize="11" FontWeight="SemiBold" Margin="2,0,0,12"/>
                    <!-- 4 columns at full width, then 3 / 2 / 1 as the pane narrows (cards stretch to share it). -->
                    <ctl:ResponsiveWrapPanel x:Name="templatesPanel" ItemWidth="240" MaxColumns="4" ItemSpacing="12"
                                             CapLayout="Center"/>
                    <StackPanel Orientation="Horizontal" Margin="2,4,0,0">
                        <Button x:Name="btnAddFromFile" Content="＋ Ajouter depuis un fichier…" Style="{StaticResource LinkBtn}" Click="btnAddFromFile_Click"
                            Foreground="{StaticResource AccentBrightBrush}" ToolTip="Choisir un fichier .json de template et l'ajouter au dossier."/>
                        <Button x:Name="btnAddWithAi" Content="🤖 Ajouter avec l'IA…" Style="{StaticResource LinkBtn}" Click="btnAddWithAi_Click" Margin="8,0,0,0"
                            Foreground="{StaticResource AccentBrightBrush}" ToolTip="Décris un style + une intention ; l'IA génère un template que tu confirmes et enregistres."/>
                    </StackPanel>

                </StackPanel>


                <!-- Resources widget. Code-behind only fills txtTip (rotating tip) and newsList (changelog entries). -->
                <StackPanel Grid.Row="2" Margin="0,22,0,0">
                    <TextBlock Text="RESSOURCES" Foreground="{StaticResource AccentBrightBrush}"
                               FontSize="11" FontWeight="SemiBold" Margin="2,0,0,12"/>
                    <!-- Side by side while both fit, otherwise stacked at full width. -->
                    <ctl:ResponsiveWrapPanel ItemWidth="350" MaxColumns="2" ItemSpacing="12" CapLayout="Left">
                        <!-- Astuce du jour : today's tip, ‹ › to browse. -->
                        <Border Style="{StaticResource ResourceCard}">
                            <StackPanel>
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button x:Name="btnTipPrev" Content="‹" Style="{StaticResource ArrowBtn}" Click="btnTipPrev_Click"/>
                                        <Button x:Name="btnTipNext" Content="›" Style="{StaticResource ArrowBtn}" Click="btnTipNext_Click"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Style="{StaticResource CardBadge}">
                                            <TextBlock Text="💡" Style="{StaticResource CardBadgeGlyph}"/>
                                        </Border>
                                        <TextBlock Text="ASTUCE DU JOUR" Style="{StaticResource CardTitle}"/>
                                    </StackPanel>
                                </DockPanel>
                                <!-- MinHeight (not a fixed width) keeps the card from resizing between tips of
                                     different lengths, while still letting the text use the full card width. -->
                                <TextBlock x:Name="txtTip" TextWrapping="Wrap" Foreground="{StaticResource CommonForeground}"
                                           FontSize="12" Margin="0,8,0,0" MinHeight="54"/>
                            </StackPanel>
                        </Border>

                        <!-- Nouveautés : built-in list, then refreshed from the repo's CHANGELOG.md. -->
                        <Border Style="{StaticResource ResourceCard}">
                            <StackPanel>
                                <DockPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Style="{StaticResource CardBadge}">
                                            <TextBlock Text="🆕" Style="{StaticResource CardBadgeGlyph}"/>
                                        </Border>
                                        <TextBlock Text="NOUVEAUTÉS" Style="{StaticResource CardTitle}"/>
                                    </StackPanel>
                                </DockPanel>
                                <StackPanel x:Name="newsList" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </ctl:ResponsiveWrapPanel>
                </StackPanel>




            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
