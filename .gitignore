# --- Visual Studio / build output ---
.vs/
[Bb]in/
[Oo]bj/
*.suo
*.user

# --- Claude Code ---
.claude/

# --- NuGet ---
# Restored from packages.config (Visual Studio restores automatically on build; from the
# command line use "nuget restore MusicTracker.sln" before the first msbuild).
packages/

# --- SoundFonts ---
# Third-party binary assets of several hundred MB (SGM 347 MB, MuseScore_General 206 MB,
# FluidR3 142 MB) — over GitHub's 100 MB per-file limit, so they are not version-controlled
# and are no longer referenced by the .csproj. Place them by hand in a "SoundFont" folder
# next to the executable (resolved through AppPaths.Local).
SoundFont/
*.sf2

# --- Generated output at the repo root ---
# The compose_*/gen_* scripts write their scores and MIDI next to the .sln; these are
# regenerable outputs, not sources. (Data/ and MusicTracker/ are unaffected: root-only.)
/*.mscx
/*.mscz
/*.mid
/*.midi
/*.wav
/*.mp3

# --- Utility / analysis scripts at the repo root ---
# Offline tooling kept locally only (corpus analysis, .mscx generation, probes). Root-only,
# so the projects' own sources are unaffected.
/*.ps1
/*.py
/*.sh
/AudioProbe.cs
/test_ajustement_modal.cs

# --- Corpora / MIDI sources ---
# Third-party scores used only OFFLINE to (re)generate the analysis models in
# MusicTracker/Data/models/*.json. Those generated models ARE version-controlled, since the
# app needs them at runtime and they can no longer be rebuilt from a fresh clone.
corpus/
midi/
